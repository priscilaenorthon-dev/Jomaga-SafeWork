# ============================================================
# Supabase — Required
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ============================================================
# Google Gemini AI — Required for DDS AI generation
# NOTE: Use GEMINI_API_KEY (server-side only, not NEXT_PUBLIC_)
#       The app calls /api/generate-dds which uses this key
#       without exposing it to the browser.
# ============================================================
GEMINI_API_KEY="your-gemini-api-key"

# ============================================================
# App URL — Used for auth callbacks
# ============================================================
APP_URL="https://your-app.vercel.app"
