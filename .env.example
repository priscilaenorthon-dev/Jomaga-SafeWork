# ============================================================
# Supabase — Required
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ============================================================
# Google Gemini AI — Required for DDS AI generation
# NOTE: Use one of:
#       - OPENROUTER_API_KEY (preferred for OpenRouter)
#       - GEMINI_API_KEY
#       - GOOGLE_AI_STUDIO_API_KEY
#       - GOOGLE_API_KEY
#       - GOOGLE_GENERATIVE_AI_API_KEY
#       (all server-side only, never NEXT_PUBLIC_)
#       Compatibility accepted by API (legacy setups):
#       - NEXT_PUBLIC_GEMINI_API_KEY
#       - NEXT_PUBLIC_GOOGLE_AI_STUDIO_API_KEY
#       The app calls /api/generate-dds which uses this key
#       without exposing it to the browser.
# ============================================================
OPENROUTER_API_KEY="your-openrouter-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# Optional: OpenRouter model (default: google/gemini-2.0-flash-001)
# OPENROUTER_MODEL="google/gemini-2.0-flash-001"

# ============================================================
# App URL — Used for auth callbacks
# ============================================================
APP_URL="https://your-app.vercel.app"
